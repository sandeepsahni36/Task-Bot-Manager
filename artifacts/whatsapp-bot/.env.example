# -------------------------------------------------------
# Copy this file to .env for local development.
# Never commit .env — it is listed in .gitignore.
# -------------------------------------------------------

# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API — https://developers.facebook.com/apps/<your-app>/whatsapp/
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Test / default numbers (international format, no +)
TEST_WHATSAPP_TO=
OWNER_WHATSAPP_NUMBER=
DEFAULT_OPS_WHATSAPP_NUMBER=

# Hostfully PMS — https://platform.hostfully.com/settings/api
HOSTFULLY_API_KEY=
HOSTFULLY_AGENCY_UID=
# Optional — defaults to https://api.hostfully.com/v2
HOSTFULLY_BASE_URL=

# -------------------------------------------------------
# Frontend (ops-ui) — Netlify build only
# -------------------------------------------------------
# Full URL of the deployed FastAPI backend, e.g. https://your-app.replit.app
# Set this in the Netlify dashboard under Site settings → Environment variables.
# Leave empty when running on Replit (relative URLs work via the shared proxy).
VITE_API_BASE_URL=
